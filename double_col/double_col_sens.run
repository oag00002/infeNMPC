reset;
param start_time symbolic;
param end_time symbolic;
let start_time := ctime();
option solver ipopt_sens, randseed 7;
option ipopt_options "tol=1e-6 max_iter=10000" ;
reset options ;
#option solver ipopt, randseed 7;
model column2_sens.mod;
data column2_dynamic.dat;
suffix sens_state_0, IN;
suffix sens_state_1, IN;
suffix sens_state_value_1, IN;
suffix sens_sol_state_1, OUT;
suffix sens_init_constr, IN;
suffix sens_sol_state_1_z_U, OUT ;
suffix sens_sol_state_1_z_L, OUT ;
option presolve 0;
read{i in s, j in s} P[i,j] < P.txt;


#let termnorm := termnorm_b2 ; 
#let termnorm:=.13;
let nfe := Nmax ;
let Nk[0] := nfe ;
#set nominal feed comp
let nominal_zF[1] := 0.4 ;#
let nominal_zF[2] := 0.2 ;#
let nominal_zF[3] := 0.4 ;


#define sens vars
for {i in 1..NT,j in 1..2}{
	let x1_0[i,j,0].sens_state_0:=i+(j-1)*NT; 
	let x1_0[i,j,0].sens_state_1:= i+(j-1)*NT; 
	let x1_0[i,j,0].sens_state_value_1:=x1set[i,j] ; 
	} ; 
	
	
	
for {i in 1..NT}{
	let M1_0[i,0].sens_state_0:=2*NT+i ; 
	let M1_0[i,0].sens_state_1:=2*NT+i ; 
	let M1_0[i,0].sens_state_value_1:=M1set[i] ; 	
	};
	
for {i in 1..NT,j in 1..2}{	
	let x2_0[i,j,0].sens_state_0:= 3*NT+i+(j-1)*NT; 
	let x2_0[i,j,0].sens_state_1:= 3*NT+i+(j-1)*NT; 
	let x2_0[i,j,0].sens_state_value_1:=x2set[i,j] ; 
	} ; 
	
	
for {i in 1..NT}{
	let M2_0[i,0].sens_state_0:=5*NT+i ; 
	let M2_0[i,0].sens_state_1:= 5*NT+i; 
	let M2_0[i,0].sens_state_value_1:=M2set[i] ; 
	};	
	


#define sens cons

for {i in 1..NT,j in 1..2}{
let x1_init_constr[i,j].sens_init_constr:=1;
let x2_init_constr[i,j].sens_init_constr:=1;
};


for {i in 1..NT}{
let M1_init_constr[i].sens_init_constr:=1;
let M2_init_constr[i].sens_init_constr:=1;
};


#Initialize first NLP
let {k in 0..K-1} F_rand[k] := Normal(0,F_dev) ;
let {k in 0..K-1, i in 1..2} zF_rand[k,i] := Normal(0,zF_dev) ;
	let  F := nominal_F; 
	let pV:= nominal_pV ; 
	let qF:= nominal_qF ; 
	let {i in 1..3} zF[i] := nominal_zF[i]; 
/*
#repeated uncertainty
for {k in 50..99}{
let F_rand[k] := F_rand[k-25] ; 
let {i in 1..2} zF_rand[k,i] := zF_rand[k-25,i] ;

};

for {k in 100..149}{
let F_rand[k] := F_rand[k-25] ; 
let {i in 1..2} zF_rand[k,i] := zF_rand[k-25,i] ;
};
*/

#include steady_state_a2.run;


#initialize at steady state
/*
for {j in 1..NT}{
let x1set[j,1]:=x1ref[j,1] ; 
let x1set[j,2]:=x1ref[j,2] ;
let x2set[j,1]:=x2ref[j,1] ;
let x2set[j,2]:=x2ref[j,2] ;
let M1set[j]:=M1ref[j];
let M2set[j]:=M2ref[j];
};
*/
/*
#read initial condition
for {j in 1..2}{
for {i in 1..NT}{
read x1set[i,j]<end_p2_unc.tab;
}}

for {j in 1..2}{
for {i in 1..NT}{
read x2set[i,j]<end_p2_unc.tab;
}}

for {i in 1..NT}{
read M1set[i]<end_p2_unc.tab;
}

for {i in 1..NT}{
read M2set[i]<end_p2_unc.tab;
}
*/

#define first real state
for {j in 1..NT}{
let state_act[j,0] := x1set[j,1];
let state_act[NT+j,0] := x1set[j,2];
let state_act[2*NT+j,0] := M1set[j] ; 
let state_act[3*NT+j,0] := x2set[j,1];
let state_act[4*NT+j,0] := x2set[j,2];
let state_act[5*NT+j,0] := M2set[j] ; 
};
let xak[0] := x1set[41,1] ; 
let xbk[0] := x2set[41,2] ; 
let xck[0] := 1 - x2set[1,1]-x2set[1,2] ; 


#Define regularization weights
include weights.run; 

/*
for {j in 1..NT}{
let x1set[j,1]:=x1ref[j,1] ; 
let x1set[j,2]:=x1ref[j,2] ;
let x2set[j,1]:=x2ref[j,1] ;
let x2set[j,2]:=x2ref[j,2] ;
let M1set[j]:=M1ref[j];
let M2set[j]:=M2ref[j];
};
*/
#include steady_state_a2.run;
include first_init.run;


#####################
#     NMPC Loop     #
#####################
for {k in 0..K-1}{

display k ;

/*
#first setpoint change######
if k = 50 then { 
let Nk[k] := Nmax ; 
let nfe := Nk[k];
