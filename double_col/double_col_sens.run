include first_init.run;
};

###################################


#second setpoint change######
if k = 100 then{
let Nk[k] := Nmax ;
let nfe := Nk[k] ;  
include steady_state_a2.run ;
include first_init.run ; 
};               
############################
*/
display nfe; 

let normx[k] := (sum {i in 1..NT}(sum{j in 1..2}((x1set[i,j]-x1ref[i,j])^2 +(x2set[i,j]-x2ref[i,j])^2 )) + sum {i in 1..NT}( (M1set[i]-M1ref[i])^2 + (M2set[i]-M2ref[i])^2))^(.5) ;


	
	#set real feed flow and comp
let F_r := F + noise_switch*F_rand[k] ;
if F_r < 0 then let F_r := 0 ;
let Fk[k] := F_r ; 

let {i in 1..2} zF_r[i] := zF[i] + noise_switch*zF_rand[k,i];
for {i in 1..2}{
if zF_r[i] < 0 then let zF_r[i]:= 0 ;
if zF_r[i] > 1 then let zF_r[i] := 1 ; 
};
if sum{i in 1..2} zF_r[i] > 1 then let zF_r[2] := 1 - zF_r[1] ; 
let zF_r[3] := 1-zF_r[1] - zF_r[2] ; 
for {i in 1..3}{
	let zFk[k,i] := zF_r[i] ; 
	}; 


#solve full NMPC
		solve;
		let step_time[k] := _solve_time;	
		let sol_stat[k] := solve_result_num;
		#let step_cost[k]:= cost[0];
		
		#compute term step 
		for {q in 0..nfe}{
		let normz[k,q] := (sum {i in 1..NT}(sum{j in 1..2}((x1_0[i,j,q]-x1ref[i,j])^2 +(x2_0[i,j,q]-x2ref[i,j])^2 )) + sum {i in 1..NT}( (M1_0[i,q]-M1ref[i])^2 + (M2_0[i,q]-M2ref[i])^2))^(.5); 
		};	
		let jj := 0 ;
repeat while normz[k,jj] > termnorm +.001{
let jj := jj+1;
};
let term_step[k]:= jj ;
		#find next real state   

#state noise
/*		
		for {j in 1..NT}{
		let x1_r[j,1,3] := x1_r[j,1,3] +state_noise_switch*Normal(0,state_dev) ;
		if x1_r[j,1,3] <= 0 then let x1_r[j,1,3] := 0 ; 
		if x1_r[j,1,3] >=1 then let x1_r[j,1,3] := 1 ; 
		
		let x1_r[j,2,3] := x1_r[j,2,3] + state_noise_switch*Normal(0,state_dev);
			if x1_r[j,2,3] <= 0 then let x1_r[j,2,3] := 0 ; 
		if x1_r[j,2,3] >=1 then let x1_r[j,2,3] := 1 ; 
		
		
     	let x2_r[j,1,3] := x2_r[j,1,3] + state_noise_switch*Normal(0,state_dev);
     		if x2_r[j,1,3] <= 0 then let x2_r[j,1,3] := 0 ; 
		if x2_r[j,1,3] >=1 then let x2_r[j,1,3] := 1 ; 
     	
     	
     	
		let x2_r[j,2,3] := x2_r[j,2,3] + state_noise_switch*Normal(0,state_dev);
				if x2_r[j,2,3] <= 0 then let x2_r[j,2,3] := 0 ; 
		if x2_r[j,2,3] >=1 then let x2_r[j,2,3] := 1 ; 
		
		
		
		let M1_r[j,3] := M1_r[j,3]+ state_noise_switch*Normal(0,state_dev);
	if M1_r[j,3] <= 0 then let M1_r[j,3] := 0 ; 
		
		
		
		
		let M2_r[j,3] := M2_r[j,3]+ state_noise_switch*Normal(0,state_dev);	
	if M2_r[j,3] <= 0 then let M2_r[j,3] := 0 ; 			
		};
		*/
#define next state		
			for {j in 1..NT}{
		let state_act[j,k+1] := x1_r[j,1,3] ;
		let state_act[NT+j,k+1] := x1_r[j,2,3] ;
	let state_act[2*NT+j,k+1]:= x2_r[j,1,3] ;
		let state_act[3*NT+j,k+1] := x2_r[j,2,3] ;
		let state_act[4*NT+j,k+1] := M1_r[j,3];
		let state_act[5*NT+j,k+1] := M2_r[j,3];
        };   	

let xak[k+1] := x1_r[41,1,3] ; 
let xbk[k+1] := x2_r[41,2,3] ; 
let xck[k+1] := 1 - x2_r[1,1,3]-x2_r[1,2,3] ; 


#define implemented control
let uk[1,k] := D1[0];
let uk[2,k] := B1[0] ;
let uk[3,k ] := LT1[0] ;
let uk[4,k] := VB1[0] ; 
let uk[5,k] := D2[0] ;
let uk[6,k] := B2[0] ;
let uk[7,k] := LT2[0] ;
let uk[8,k] := VB2[0];        
       

 /*
 ###############
 ###start sens###
 ###############
      	#define initial condition for sensitivity 
      	
  	for {j in 1..NT}{
		let x1set[j,1] := x1_0[j,1,1] ;
		let x1set[j,2] := x1_0[j,2,1] ;
		let x2set[j,1] := x2_0[j,1,1] ;
		let x2set[j,2] := x2_0[j,2,1] ;
		let M1set[j] := M1_0[j,1];
		let M2set[j] := M2_0[j,1];
		
        }; 
      	
      	#define parameter for sensitivity 
      	
	for {j in 1..NT}{
		let x1_0[j,1,0].sens_state_value_1 := x1_r[j,1,3] ;
		let x1_0[j,2,0].sens_state_value_1:= x1_r[j,2,3] ;
		let x2_0[j,1,0].sens_state_value_1 := x2_r[j,1,3] ;
		let x2_0[j,2,0].sens_state_value_1 := x2_r[j,2,3] ;
		let M1_0[j,0].sens_state_value_1 := M1_r[j,3];
		let M2_0[j,0].sens_state_value_1 := M2_r[j,3];
	
        }; 
      	
      	 #intitialize sensitivity 
      	 
      	 #include nmpc_init.run;
      	 
      	 
      	 
      	 #run sens
      	 solve;
		let sens_sol_stat[k] := solve_result_num;
      	 
      	 #compute sense term step 
      	 	for {q in 0..nfe}{
		let normz_sens[k,q] := (sum {i in 1..NT}(sum{j in 1..2}((x1_0[i,j,q].sens_sol_state_1-x1ref[i,j])^2 +(x2_0[i,j,q].sens_sol_state_1-x2ref[i,j])^2 )) + sum {i in 1..NT}( (M1_0[i,q].sens_sol_state_1-M1ref[i])^2 + (M2_0[i,q].sens_sol_state_1-M2ref[i])^2))^(.5); 
		};	
				let jj := 0 ;
repeat while normz_sens[k,jj] > termnorm + .001 {
let jj := jj+1;
};
let sens_term_step[k]:= jj ;
let Nk[k+1]:=sens_term_step[k]+Ns;
let nfe := Nk[k+1];
############
#######end sens#####
#############
*/

      	 #define initial condition for next NMPC
      	 
      	   	for {j in 1..NT}{
		let x1set[j,1] := 	state_act[j,k+1] ;
		let x1set[j,2] := state_act[NT+j,k+1] ;
		let x2set[j,1] := state_act[2*NT+j,k+1];
		let x2set[j,2] := state_act[3*NT+j,k+1] ;
		let M1set[j] := state_act[4*NT+j,k+1];
		let M2set[j] := state_act[5*NT+j,k+1];
		
        }; 
        
print k,normx[k],termeps> n10rho100000.tab;
