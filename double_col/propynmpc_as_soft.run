#printf: "%e ",           Psteam[i] >>control.dat;
#printf: "%e ",           Reflux[i]>>control.dat;
printf "\n" >>control.dat;
}
printf "\n" >>control.dat;
close control.dat;

shell "rm origControl.dat";
for {i in fe}{
printf: "%e ",           D[i]>>origControl.dat;
printf: "%e ",           B[i]>>origControl.dat;
printf: "%e ",           Psteam[i]>>origControl.dat;
printf: "%e ",           Reflux[i]>>origControl.dat;
#printf: "%e ",           D[i]>>control.dat;
#printf: "%e ",           B[i] >>control.dat;
#printf: "%e ",           Psteam[i] >>control.dat;
#printf: "%e ",           Reflux[i]>>control.dat;
printf "\n" >>origControl.dat;
}
printf "\n" >>origControl.dat;
close origControl.dat;

shell "rm M0.dat";
shell "rm x0.dat";
for {i in tray}{
    for {j in fe}{
        printf:"%e ",M_0[i,j].sens_sol_state_1>>M0.dat;
        printf:"%e ",x_0[i,j].sens_sol_state_1>>x0.dat;
#        printf:"%e ",M_0[i,j]>>M0.dat;
#        printf:"%e ",x_0[i,j]>>x0.dat;
    }
    printf "\n">>M0.dat;
    printf "\n">>x0.dat;
}

close M0.dat;
close x0.dat;

shell "rm VU.dat";
shell "rm VL.dat";
shell "rm Eps.dat";

for {i in tray}{
    for {j in fe}{
        for {k in cp}{
            printf:"%e ",Meps[i,j,k]>>Eps.dat;
            printf "\n">>Eps.dat;
#            printf:"%e ",M.ipopt_zU_out[i,j,k]>>VU.dat;
#            printf:"%e ",M.ipopt_zL_out[i,j,k]>>VL.dat;
