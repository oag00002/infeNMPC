}
}
}

for {i in tray}{
    for {j in fe}{
        for {k in cp}{
            printf:"%e ",xeps[i,j,k]>>Eps.dat;
            printf "\n">>Eps.dat;
}
}
}


close Eps.dat;

display xeps[1,1,1],xeps[1,1,2],Meps[1,1,1],Meps[1,1,2];

close VU.dat;
close VL.dat;

shell "rm vio.dat";

printf: "%e ",           D[1].sens_sol_state_1 >>vio.dat;
printf: "%e ",           B[1].sens_sol_state_1 >>vio.dat;
printf: "%e ",           Psteam[1].sens_sol_state_1 >>vio.dat;
close vio.dat;

shell "rm origVio.dat";

printf: "%e ",           D[1] >>origVio.dat;
printf: "%e ",           B[1] >>origVio.dat;
printf: "%e ",           Psteam[1] >>origVio.dat;
close origVio.dat;
