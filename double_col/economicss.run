###########################################################################
# RUN FILE COLUMN 1 AND 2 #################################################
###########################################################################

reset ;

### load model
model economicss.mod;
data economicss.dat;

#-----------
# Options
#-----------
option solver ipopt;
#option show_stats 1 ;
#option display_precision 0;

### turn presolve off
option presolve 0;
option auxfiles 'rc';
write gvars;


########
# Solve
########

solve;

#########
# Print
##########
